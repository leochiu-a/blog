---
import '../styles/globals.css';

interface Props {
  title?: string;
  description?: string;
  dark?: boolean;
}

const {
  title = 'Home • Leo Chiu',
  description = 'Frontend engineer & developer',
  dark = false,
} = Astro.props;
---

<!doctype html>
<html lang="en" class={dark ? 'dark' : ''}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/seo/icon.svg" />
    <link rel="apple-touch-icon" href="/seo/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&family=Alegreya:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="flex justify-center bg-background scroll-smooth font-garamond antialiased">
    <slot />
  </body>
</html>
